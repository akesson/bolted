# bolted constraint surface
# feature: gen-profile
# snapshot-format: v1
# stash-schema-version: 1
#
# Generated by `mise run gen:ffi`; byte-checked by `mise run check`. Nothing formats this
# file (D28), which is what makes the byte comparison honest. A diff here is a change to the
# constraint surface: review it, decide whether STASH_SCHEMA_VERSION must move (D27 — a
# *tightening* strands every stashed draft whose raw no longer parses), then regenerate with
# `mise run gen:ffi`. The schema version is a human-bumped constant
# (crates/bolted-ffi-gen/src/dto.rs), never auto-derived from these constraints: that is
# D27's own rejected alternative, because a *loosening* would kill every stash for no reason.

[values]

value Username
  raw String
  sanitize trim
  validate len_chars(min = 3, max = 20)
  validate custom(ascii_alnum_underscore) variant=InvalidChars key=invalid_chars constraint=ascii_alnum_underscore
  error TooShort key=too_short params=(min: u32, actual: u32)
  error TooLong key=too_long params=(max: u32, actual: u32)
  error InvalidChars key=invalid_chars params=()

value PersonName
  raw String
  sanitize trim
  validate len_chars(min = 1, max = 30)
  error TooShort key=too_short params=(min: u32, actual: u32)
  error TooLong key=too_long params=(max: u32, actual: u32)

value Email
  raw String
  sanitize trim
  sanitize lowercase
  validate custom(email) variant=Invalid key=invalid_email constraint=email
  error Invalid key=invalid_email params=()

[entity]

entity Profile
  field username type=Username source=declared
    check rule=username_unique pending_key=username_check_pending required_key=username_check_required failed_key=username_taken
  field name type=PersonName source=declared
  field email type=Email source=declared
  field availability type=DateRange source=custom

[rules]
rule corporate_email pins=Email

[runtime-constraints]
username: Required, LenChars { min: 3, max: 20 }, Custom("ascii_alnum_underscore")
name: Required, LenChars { min: 1, max: 30 }
email: Required, Custom("email")
availability: Required, Custom("start_le_end")
