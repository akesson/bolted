<?xml version="1.0" encoding="utf-8"?>
<!--
  Step 14. The probe consumes the packed artifact as a real NuGet package (the native dylib rides in
  it under runtimes/osx-arm64/native), not as a project reference — that exercises the full `pack`
  distribution path, which is the point of a pack tier. `local` is the folder feed `pack:csharp`
  writes; nuget.org supplies NUnit + the test SDK. `test:csharp` busts the global-cache entry for
  gen_profile_ffi before restoring, since the version is fixed at 0.1.0 across re-packs.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="local" value="../../crates/gen-profile-ffi/dist/csharp/packages" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
