# Claude Code: personal settings stay local; .claude/memory/ IS committed (see CLAUDE.md)
.claude/settings.local.json

# Generated by Cargo
# will have compiled files and executables
debug
target

# Step 02/03 Apple packages: generated by `boltffi pack apple` and `swift build/test` — artifacts.
crates/spike-profile-ffi/dist/
# Step 10: the generated FFI crates pack into the same place.
crates/gen-profile-ffi/dist/
crates/gen-note-ffi/dist/
apple/profile-probe/.build/
apple/profile-app/.build/
# Step 10: the generated-bindings smoke package.
apple/gen-profile-smoke/.build/

# Step 03 XCUITest tier (mise run test:apple:ui): the .xcodeproj is generated from project.yml by
# XcodeGen; only project.yml + UITests/ are committed. Build output stays local.
apple/profile-app/*.xcodeproj/
apple/profile-app/.build-xcode/
apple/profile-app/DerivedData/

# Step 04 web spike: Trunk's bundle output (mise run build:web / serve:web) — artifacts.
crates/profile-web/dist/

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

# Step 05 — Android probe build artifacts
android/profile-probe/build/
android/profile-probe/.gradle/
android/profile-probe/local.properties

# Step 07 — Compose spike app build artifacts
android/profile-app/build/
android/profile-app/.gradle/
android/profile-app/local.properties

# Step 11 — generated-bindings Kotlin smoke module build artifacts
android/gen-profile-smoke/build/
android/gen-profile-smoke/.gradle/
android/gen-profile-smoke/local.properties

# Step 14 — C# probe build artifacts (dotnet). The packed .nupkg rides in gen-profile-ffi/dist/,
# already ignored above; only the hand-written + committed-generated sources are tracked.
csharp/profile-probe/bin/
csharp/profile-probe/obj/
csharp/profile-probe/TestResults/

# Step 18 — OS-integration spike: the Swift probe's build output (mise run test:os:sandbox).
spikes/os-integration/apple/sync-probe/.build/
