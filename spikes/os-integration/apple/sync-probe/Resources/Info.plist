<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Embedded into the binary as __TEXT,__info_plist: App Sandbox refuses to initialize a
	     process with no bundle identity (verified: SIGTRAP in _libsecinit_appsandbox without
	     this). The identifier keys the sandbox container under ~/Library/Containers/. -->
	<key>CFBundleIdentifier</key>
	<string>dev.bolted.sync-probe</string>
	<key>CFBundleName</key>
	<string>sync-probe</string>
	<key>CFBundleVersion</key>
	<string>1</string>
</dict>
</plist>
